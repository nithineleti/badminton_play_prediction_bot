{
  "version": 2,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "python3.9",
      "includeFiles": "api/** src/**",
      "excludeFiles": "experiments/** data/** **/*.keras **/*.pkl **/*.h5 **/*.pb **/*.onnx"
    }
  },
  "env": {
    "PYTHONPATH": "."
  }
}
